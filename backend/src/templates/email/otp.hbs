<!doctype html><html><body style="font-family:Arial,sans-serif;background:#f5f7fb;padding:40px;">
  <div style="max-width:560px;margin:auto;background:#fff;border-radius:12px;padding:36px;box-shadow:0 2px 12px rgba(0,0,0,.06)">
    <h2 style="color:#111;margin:0 0 12px">Your verification code</h2>
    <p style="color:#444">Use the code below to {{#if (eq purpose "password_reset")}}reset your password{{else}}verify your email{{/if}}. It expires in 10 minutes.</p>
    <div style="font-size:32px;letter-spacing:8px;font-weight:700;background:#f1f5ff;color:#1d4ed8;padding:16px;text-align:center;border-radius:10px;margin:24px 0">{{code}}</div>
    <p style="color:#777;font-size:13px">If you didn't request this, you can safely ignore this email.</p>
    <hr style="border:none;border-top:1px solid #eee;margin:24px 0"/>
    <p style="color:#aaa;font-size:12px">© {{year}} CRM Platform</p>
  </div>
</body></html>