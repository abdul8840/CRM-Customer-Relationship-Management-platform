    "axios": "^1.18.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fast-csv": "^5.0.7",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.12.0",
    "node-cron": "^4.5.0",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.5",
    "sib-api-v3-sdk": "^8.5.0",
    "slugify": "^1.6.9",
